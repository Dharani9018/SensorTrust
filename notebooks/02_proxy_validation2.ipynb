   "source": [
    "sync_base = (\n",
    "        Path.home()\n",
    "        / \"SensorTrust\"\n",
    "        / \"datasets\"\n",
    "        / \"kitti\"\n",
    "        / \"2011_09_26\"\n",
    "        / \"2011_09_26_drive_0009_sync\"\n",
    ")\n",
    "\n",
    "\n",
    "def load_timestamps(filepath):\n",
    "    timestamps = []\n",
    "\n",
    "    with open(filepath , \"r\") as f:\n",
    "\n",
    "        for line in f:\n",
    "\n",
    "            line = line.strip()\n",
    "\n",
    "            if not line:\n",
    "                continue\n",
    "\n",
    "            date_part , time_part = line.split(\" \")\n",
    "\n",
    "            whole , frac = time_part.split(\".\")\n",
    "\n",
    "            frac = frac[:6]\n",
    "\n",
    "            dt_obj = datetime.strptime(\n",
    "                f\"{date_part} {whole}.{frac}\" ,\n",
    "                \"%Y-%m-%d %H:%M:%S.%f\"\n",
    "            )\n",
    "\n",
    "            timestamps.append(dt_obj.timestamp())\n",
    "\n",
    "    return np.array(timestamps)\n",
    "\n",
    "\n",
